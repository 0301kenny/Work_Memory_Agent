{
  "name": "work-memory-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A personal desktop work memory assistant for local-first meeting notes and summaries.",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:schedule-test": "WMA_TEST_SCHEDULE=1 electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0"
  },
  "build": {
    "appId": "com.workmemoryagent.desktop",
    "productName": "Work Memory Agent",
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}
